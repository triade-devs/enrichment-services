# URL do projeto Supabase usado pelo ERP (a mesma de NEXT_PUBLIC_SUPABASE_URL).
# O ERP repassa o access_token da sessão; este serviço o valida contra as signing keys
# públicas do projeto, buscadas em ${SUPABASE_URL}/auth/v1/.well-known/jwks.json (ES256).
# Sobrevive a rotação de chaves — não precisa de segredo simétrico.
SUPABASE_URL=https://<project-ref>.supabase.co

# Porta do serviço. Em dev local use 3001 para não colidir com o Next.js (3000).
PORT=3001
